# PreXiv environment variables — copy to .env and fill in.
# Every var here is OPTIONAL in development. Required-in-production vars are
# called out in the comment above each one.

# ─── server ────────────────────────────────────────────────────────────────

# Port the HTTP server binds to.
PORT=3000

# Required when NODE_ENV=production. Anything sufficiently long & random will
# do; rotating this invalidates every existing session cookie.
SESSION_SECRET=change-me-to-a-long-random-string

# Set to "production" to enforce secure cookies, trust proxy headers, and
# enable rate limiting. Leave unset for local dev.
NODE_ENV=production

# Absolute base URL the app uses in verify/reset email links and in citation
# `url` fields. Falls back to reflecting the incoming request's host header
# when unset, which is fine on localhost but wrong behind a proxy.
APP_URL=https://prexiv.example.com

# ─── storage ──────────────────────────────────────────────────────────────

# Directory the SQLite DB and session store live in. Use a persistent disk
# in production. Defaults to ./data .
DATA_DIR=/var/lib/prexiv

# Directory uploaded PDFs are stored in. Defaults to ./public/uploads .
UPLOAD_DIR=/var/lib/prexiv/uploads

# ─── rate limiting ────────────────────────────────────────────────────────

# In dev (NODE_ENV != production), rate limits are skipped for ergonomics.
# Set RATE_LIMIT=1 to enable the limiters in dev too.
RATE_LIMIT=1

# ─── moderation ───────────────────────────────────────────────────────────

# Comma-separated usernames; matching users are auto-promoted to admin on
# every server start. Useful for bootstrapping a moderator on a fresh deploy.
ADMIN_USERNAMES=eulerine,noether42

# ─── DOI integration (optional) ───────────────────────────────────────────

# Personal access token from zenodo.org / sandbox.zenodo.org. When set, every
# new submission is deposited and published on Zenodo and gets a real DOI.
# Without this, manuscripts get a synthetic 10.99999/PREXIV:* identifier.
ZENODO_TOKEN=eyJ0eXAiOi…

# Set to "1" to use production Zenodo (permanent DOIs, irrevocable). Default
# behaviour with ZENODO_TOKEN set is to use Zenodo sandbox.
ZENODO_USE_PRODUCTION=0

# ─── runtime DB persistence ───────────────────────────────────────────────

# Default behaviour persists everything users add across restarts. Set to "1"
# to instead replace data/prearxiv.db with a copy of data/prearxiv.seed.db on
# every server start (so each restart returns to the seeded demo state).
PREXIV_WIPE_ON_RESTART=0

# Force-disable PREXIV_WIPE_ON_RESTART regardless of its value. Set internally
# by `npm run seed` so the seeder doesn't wipe its own output. You normally
# don't need to touch this.
PREXIV_SKIP_RESET=0

# Legacy alias for PREXIV_SKIP_RESET. Kept for backwards compatibility.
PREXIV_PERSIST=0

# ─── diagnostics ──────────────────────────────────────────────────────────

# Set to "1" to make the API pretend every manuscript has incoming citations,
# forcing hard-delete attempts to fall through to withdrawal-with-tombstone.
# Used to exercise the citation-protection code path in tests.
PREXIV_PRETEND_CITATIONS=0

# Set to "1" to log webhook-delivery failures (network errors, timeouts) to
# stderr. Default behaviour is silent so a misconfigured user webhook doesn't
# spam the server log.
PREXIV_WEBHOOK_DEBUG=0
