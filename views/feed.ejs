<% const pageTitle = 'feed' %>
<%- include('partials/header', { pageTitle }) %>

<div class="page-header">
  <h1>Your feed</h1>
  <p class="muted">Manuscripts from people you follow, newest first.</p>
</div>

<% if (manuscripts.length === 0) { %>
  <div class="empty">
    <p>Your feed is empty.</p>
    <p class="muted">Follow other PreXiv users (from their <code>/u/&lt;username&gt;</code> page) and their submissions will appear here.</p>
    <p><a href="/" class="btn-primary">Browse the ranked feed →</a></p>
  </div>
<% } else { %>
  <ol class="ms-list">
    <% for (let i = 0; i < manuscripts.length; i++) { const m = manuscripts[i]; const rank = (page - 1) * per + i + 1; %>
      <%- include('partials/manuscript_row', { m, rank, voteMap, CATEGORIES, escapeHtml, timeAgo, isSafeExternalUrl }) %>
    <% } %>
  </ol>

  <nav class="pagination" aria-label="Pagination">
    <% if (page > 1) { %>
      <a href="?page=<%= page - 1 %>">← previous</a>
    <% } %>
    <span class="muted">page <%= page %></span>
    <% if (manuscripts.length === per) { %>
      <a href="?page=<%= page + 1 %>">next →</a>
    <% } %>
  </nav>
<% } %>

<%- include('partials/footer') %>
