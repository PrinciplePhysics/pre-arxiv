<% const pageTitle = 'register' %>
<%- include('partials/header', { pageTitle }) %>

<div class="auth-card">
  <h1>Register</h1>
  <p class="muted small">All accounts are equal. There are no “verified expert” badges; readers calibrate from your stated role and affiliation.</p>
  <% if (errors && errors.length) { %>
  <div class="form-errors"><ul><% for (const e of errors) { %><li><%= e %></li><% } %></ul></div>
  <% } %>
  <form action="/register" method="post">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label><span class="label-text">Username <span class="req">*</span></span>
      <input type="text" name="username" required maxlength="32" pattern="[a-zA-Z0-9_-]+" value="<%= escapeHtml((values && values.username) || '') %>">
    </label>
    <label><span class="label-text">Email <span class="req">*</span></span>
      <input type="email" name="email" required maxlength="200" value="<%= escapeHtml((values && values.email) || '') %>">
    </label>
    <label><span class="label-text">Password <span class="req">*</span></span>
      <input type="password" name="password" required minlength="8">
      <span class="hint">≥ 8 characters.</span>
    </label>
    <label><span class="label-text">Display name</span>
      <input type="text" name="display_name" maxlength="200" value="<%= escapeHtml((values && values.display_name) || '') %>" placeholder="e.g., Jane Doe">
    </label>
    <label><span class="label-text">Affiliation</span>
      <input type="text" name="affiliation" maxlength="200" value="<%= escapeHtml((values && values.affiliation) || '') %>" placeholder="e.g., MIT · Reed College · independent">
    </label>
    <label><span class="label-text">Anti-bot check <span class="req">*</span></span>
      <span class="captcha-q">What is <strong><%= captcha.a %> <%= captcha.op %> <%= captcha.b %></strong>?</span>
      <input type="text" name="captcha" required inputmode="numeric" pattern="-?[0-9]+" maxlength="6" autocomplete="off" style="max-width: 120px">
    </label>
    <button type="submit" class="btn-primary">create account</button>
  </form>
  <p class="muted small">Already have one? <a href="/login">Log in</a>.</p>
</div>

<%- include('partials/footer') %>
