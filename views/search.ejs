<% const pageTitle = q ? 'search · ' + q : 'search' %>
<% const f = (typeof filters !== 'undefined' && filters) ? filters : { category: '', mode: '', dateFrom: '', dateTo: '', scoreMin: null }; %>
<%- include('partials/header', { pageTitle }) %>

<div class="page-header">
  <h1>Search</h1>
  <form action="/search" method="get" class="search-page-form" role="search">
    <label for="search-q" class="visually-hidden">Search query</label>
    <input id="search-q" type="search" name="q" value="<%= escapeHtml(q || '') %>" placeholder="title, author, id, abstract…" autofocus>
    <button type="submit" class="btn-primary">search</button>
  </form>

  <details class="search-filters" <%= (f.category || f.mode || f.dateFrom || f.dateTo || f.scoreMin != null) ? 'open' : '' %>>
    <summary>Filters<% if (f.category || f.mode || f.dateFrom || f.dateTo || f.scoreMin != null) { %> <span class="muted small">(active)</span><% } %></summary>
    <form action="/search" method="get" class="filter-form">
      <input type="hidden" name="q" value="<%= escapeHtml(q || '') %>">
      <div class="filter-grid">
        <label>
          <span class="label-text">Category</span>
          <select name="category">
            <option value="">— any —</option>
            <% for (const c of CATEGORIES) { %>
              <option value="<%= c.id %>" <%= f.category === c.id ? 'selected' : '' %>><%= c.id %> — <%= c.name %></option>
            <% } %>
          </select>
        </label>
        <label>
          <span class="label-text">Mode</span>
          <select name="mode">
            <option value=""               <%= !f.mode || f.mode === 'any' ? 'selected' : '' %>>— any —</option>
            <option value="audited"        <%= f.mode === 'audited' ? 'selected' : '' %>>audited (has auditor)</option>
            <option value="unaudited"      <%= f.mode === 'unaudited' ? 'selected' : '' %>>unaudited</option>
            <option value="agent"          <%= f.mode === 'agent' ? 'selected' : '' %>>AI agent (autonomous)</option>
            <option value="human-conducted"<%= f.mode === 'human-conducted' ? 'selected' : '' %>>human-conducted</option>
          </select>
        </label>
        <label>
          <span class="label-text">From</span>
          <input type="date" name="date_from" value="<%= escapeHtml(f.dateFrom || '') %>">
        </label>
        <label>
          <span class="label-text">To</span>
          <input type="date" name="date_to" value="<%= escapeHtml(f.dateTo || '') %>">
        </label>
        <label>
          <span class="label-text">Min score</span>
          <input type="number" name="score_min" value="<%= f.scoreMin == null ? '' : f.scoreMin %>" placeholder="0" inputmode="numeric">
        </label>
      </div>
      <div class="filter-actions">
        <button type="submit" class="btn-secondary">apply filters</button>
        <a class="muted small" href="/search?q=<%= encodeURIComponent(q || '') %>">clear</a>
      </div>
    </form>
  </details>
</div>

<% const hasQueryOrFilter = !!(q || f.category || f.mode || f.dateFrom || f.dateTo || f.scoreMin != null); %>
<% if (hasQueryOrFilter && manuscripts.length === 0) { %>
  <div class="empty-state">
    <p class="muted">No results<% if (q) { %> for <strong><%= escapeHtml(q) %></strong><% } %>.</p>
    <p class="muted small">
      Try a broader query, or
      <a href="/search?q=<%= encodeURIComponent(q || '') %>">clear filters</a>,
      or <a href="/browse">browse by category</a>,
      or <a href="/new">see what's newest</a>.
    </p>
  </div>
<% } else if (manuscripts.length) { %>
  <p class="muted small"><%= manuscripts.length %> result<%= manuscripts.length === 1 ? '' : 's' %><% if (q) { %> for <strong><%= escapeHtml(q) %></strong><% } %></p>
  <ol class="ms-list">
    <% for (let i = 0; i < manuscripts.length; i++) { const m = manuscripts[i]; %>
      <%- include('partials/manuscript_row', { m, rank: i + 1, voteMap, CATEGORIES, escapeHtml, timeAgo, isSafeExternalUrl }) %>
    <% } %>
  </ol>
<% } else { %>
  <div class="empty-state">
    <p>Start typing — the box above searches titles, authors, abstracts, manuscript ids, DOIs, and (when available) full PDF text.</p>
    <p class="muted small">
      Examples:
      <a href="/search?q=physics">physics</a> ·
      <a href="/search?q=transformer">transformer</a> ·
      <a href="/search?q=auditor">auditor</a> ·
      <a href="/search?q=&amp;mode=audited">audited only</a> ·
      <a href="/search?q=&amp;mode=agent">AI-agent only</a>
    </p>
    <p class="muted small">Or just <a href="/browse">browse by category</a>.</p>
  </div>
<% } %>

<%- include('partials/footer') %>
