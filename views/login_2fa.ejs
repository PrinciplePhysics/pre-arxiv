<% const pageTitle = '2FA' %>
<%- include('partials/header', { pageTitle }) %>

<div class="auth-card">
  <h1>Enter 2FA code</h1>
  <p class="muted">Password accepted. Enter the 6-digit code from your authenticator app to finish signing in.</p>
  <% if (errors && errors.length) { %>
    <div class="form-errors"><ul><% for (const e of errors) { %><li><%= e %></li><% } %></ul></div>
  <% } %>
  <form action="/login/2fa" method="post">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <input type="hidden" name="next" value="<%= escapeHtml(next || '/') %>">
    <label>
      <span class="label-text">6-digit code</span>
      <input type="text" name="code" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" required autocomplete="one-time-code" autofocus>
    </label>
    <button type="submit" class="btn-primary">continue</button>
  </form>
  <p class="muted small">Stuck? <a href="/login">Restart sign-in</a>.</p>
</div>

<%- include('partials/footer') %>
