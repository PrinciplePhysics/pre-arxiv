<% const pageTitle = 'browse' %>
<%- include('partials/header', { pageTitle }) %>

<div class="page-header">
  <h1>Browse by category</h1>
  <p class="muted">Categories follow the arxiv taxonomy where possible.</p>
</div>

<ul class="cat-grid">
  <% for (const c of CATEGORIES) { %>
    <li class="cat-cell">
      <a href="/browse/<%= encodeURIComponent(c.id) %>">
        <span class="cat-id"><%= c.id %></span>
        <span class="cat-name"><%= c.name %></span>
        <span class="cat-count"><%= counts[c.id] || 0 %></span>
      </a>
    </li>
  <% } %>
</ul>

<%- include('partials/footer') %>
