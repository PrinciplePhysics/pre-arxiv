<% const pageTitle = 'delete account' %>
<%- include('partials/header', { pageTitle }) %>

<article class="prose">
  <div class="page-header">
    <h1>Delete your account</h1>
    <p class="muted">GDPR right of erasure. Plain-language confirmation before we anonymize you.</p>
  </div>

  <% if (errors && errors.length) { %>
    <div class="form-errors"><ul><% for (const e of errors) { %><li><%= e %></li><% } %></ul></div>
  <% } %>

  <section class="form-section">
    <h2>What deleting your account does</h2>
    <ul>
      <li>Replaces your username with <code>deleted_<%= user.id %></code> and your email with <code>deleted_<%= user.id %>@deleted.invalid</code>. Display name, affiliation, and bio are blanked.</li>
      <li>Empties your password hash and revokes every API token you've ever minted, so the account can never be logged into again.</li>
      <li>
        Withdraws all <strong><%= counts.live_manuscripts %></strong> of your live manuscripts — they become tombstones with the reason
        "User account deleted." This preserves stable ids and DOIs so existing citations don't break.
        <% if (counts.withdrawn_manuscripts > 0) { %>
        Your <%= counts.withdrawn_manuscripts %> already-withdrawn manuscript<%= counts.withdrawn_manuscripts === 1 ? '' : 's' %> stay
        as <%= counts.withdrawn_manuscripts === 1 ? 'a tombstone' : 'tombstones' %>.
        <% } %>
      </li>
      <li>Leaves your <strong><%= counts.comments %></strong> comment<%= counts.comments === 1 ? '' : 's' %> in place — they remain attached to your now-anonymous username (<code>deleted_<%= user.id %></code>) so existing discussion threads stay coherent. Comment content is not edited.</li>
      <li>Keeps your <strong><%= counts.votes %></strong> vote<%= counts.votes === 1 ? '' : 's' %> on the books (anonymous to other users — no UI exposes who voted on what).</li>
      <li>Removes any webhook subscriptions you registered.</li>
      <li>Logs the action in the audit log so we have a record if you ever ask why your data is gone.</li>
    </ul>
    <p><strong>This cannot be undone.</strong> If you're not sure, <a href="/me/export">export your data first</a>.</p>
  </section>

  <section class="form-section">
    <h2>Confirm with your password</h2>
    <form action="/me/delete-account" method="post">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label>
        <span class="label-text">Password</span>
        <input type="password" name="password" required autocomplete="current-password" autofocus>
      </label>
      <label class="muted small" style="display:block; margin: 8px 0 12px;">
        <input type="checkbox" name="confirm" value="1" required>
        I understand this is permanent and cannot be undone.
      </label>
      <button type="submit" class="btn-secondary danger">delete my account</button>
      <a href="/u/<%= escapeHtml(user.username) %>" style="margin-left: 12px;">cancel</a>
    </form>
  </section>
</article>

<%- include('partials/footer') %>
