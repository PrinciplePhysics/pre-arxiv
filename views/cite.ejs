<% const pageTitle = 'cite — ' + m.title %>
<%- include('partials/header', { pageTitle }) %>

<article class="prose">
  <h1>Cite this manuscript</h1>
  <p class="muted small">
    <strong><%= escapeHtml(m.title) %></strong> · <%= escapeHtml(m.authors) %>
  </p>
  <p>
    <a href="/m/<%= encodeURIComponent(m.arxiv_like_id) %>">← back to manuscript</a>
  </p>

  <h2>Identifier</h2>
  <table class="kv">
    <tr><th>arxiv-like id</th><td class="mono"><%= m.arxiv_like_id %></td></tr>
    <% if (m.doi) { %><tr><th>DOI</th><td class="mono"><%= m.doi %> <span class="muted small">(synthetic — not registered with any DOI registrar)</span></td></tr><% } %>
  </table>

  <h2>BibTeX</h2>
  <pre class="cite-block"><%= bib %></pre>
  <p class="cite-actions">
    <a class="btn-secondary" href="/m/<%= encodeURIComponent(m.arxiv_like_id) %>/cite.bib">download .bib</a>
  </p>

  <h2>RIS</h2>
  <pre class="cite-block"><%= ris %></pre>
  <p class="cite-actions">
    <a class="btn-secondary" href="/m/<%= encodeURIComponent(m.arxiv_like_id) %>/cite.ris">download .ris</a>
  </p>

  <h2>Plain text</h2>
  <pre class="cite-block"><%= plain %></pre>
</article>

<%- include('partials/footer') %>
