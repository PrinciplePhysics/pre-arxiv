<% const pageTitle = m.title %>
<% const canSeeFull = (typeof isAdmin !== 'undefined' && isAdmin) || (typeof user !== 'undefined' && user && m.submitter_id === user.id); %>
<% const aiModelDisplay = (m.conductor_ai_model_public !== 0 || canSeeFull) ? m.conductor_ai_model : '(undisclosed)'; %>
<% const humanDisplay   = (m.conductor_human_public    !== 0 || canSeeFull) ? m.conductor_human    : '(undisclosed)'; %>
<% const aiModelHidden  = m.conductor_ai_model_public === 0; %>
<% const humanHidden    = m.conductor_human_public    === 0; %>
<%- include('partials/header', { pageTitle }) %>

<article class="manuscript">

  <% if (m.withdrawn) { %>
  <div class="tombstone-banner">
    <strong>Withdrawn.</strong>
    This manuscript was withdrawn <%= timeAgo(m.withdrawn_at) %>.
    <% if (m.withdrawn_reason) { %><span class="tombstone-reason">Reason: <%= escapeHtml(m.withdrawn_reason) %></span><% } %>
    The contents below are kept for citation continuity; the work no longer reflects the conductor's current view.
  </div>
  <% } else { %>

    <% if (m.conductor_type === 'ai-agent') { %>
    <div class="agent-banner">
      <strong>AI agent (autonomous).</strong>
      This manuscript was produced by <%= escapeHtml(aiModelDisplay) %> acting on its own, without ongoing human direction.
      <% if (!m.has_auditor) { %>
        <strong>No human</strong> &mdash; including the submitter &mdash; takes responsibility for its conduct or contents.
      <% } else { %>
        A human auditor has separately reviewed the contents (see auditor section below); no human directed the production itself.
      <% } %>
    </div>
    <% } %>

    <% if (!m.has_auditor && m.conductor_type !== 'ai-agent') { %>
    <div class="warn-banner">
      <strong>Unaudited manuscript.</strong>
      The submitter has explicitly stated that they are <em>not</em> responsible for the correctness of this work.
      No human expert has signed off on the contents. Treat the result with appropriate skepticism.
    </div>
    <% } else if (m.has_auditor) { %>
    <div class="audit-banner">
      <strong>Audited.</strong>
      <%= escapeHtml(m.auditor_name) %><% if (m.auditor_affiliation) { %> (<%= escapeHtml(m.auditor_affiliation) %>)<% } %>
      has read the manuscript and provided a signed correctness statement (see below).
      Audit endorses what was reviewed; it is not a guarantee.
    </div>
    <% } %>

  <% } %>

  <header class="ms-header">
    <div class="ms-id-row">
      <span class="ms-arxivid-big"><%= m.arxiv_like_id %></span>
      <% if (m.doi) { %><span class="ms-doi muted mono" title="synthetic DOI — not registered with a DOI registrar"><%= m.doi %></span><% } %>
      <a class="ms-cat-pill" href="/browse/<%= encodeURIComponent(m.category) %>"><%= m.category %></a>
      <% const _cat = CATEGORIES.find(c => c.id === m.category); if (_cat) { %><span class="muted"><%= _cat.name %></span><% } %>
      <span class="muted">·</span>
      <span class="muted">submitted <%= timeAgo(m.created_at) %></span>
      <% if (m.updated_at && m.updated_at !== m.created_at) { %>
      <span class="muted">·</span>
      <span class="muted edited-mark" title="last edited <%= m.updated_at %>">edited <%= timeAgo(m.updated_at) %></span>
      <% } %>
      <% if (typeof liveVersion !== 'undefined' && liveVersion > 0) { %>
      <span class="muted">·</span>
      <a class="muted" href="/m/<%= encodeURIComponent(m.arxiv_like_id) %>/versions" title="show full version history">v<%= liveVersion %> · earlier versions</a>
      <% } %>
      <span class="muted">·</span>
      <span class="muted"><%= m.view_count %> views</span>
    </div>
    <h1 class="ms-h1"><%= escapeHtml(m.title) %></h1>
    <div class="ms-authors-line"><%= escapeHtml(m.authors) %></div>
  </header>

  <div class="ms-actions-bar">
    <div class="ms-actions-left">
      <% if (m.pdf_path) { %><a class="btn-primary" href="<%= m.pdf_path %>" target="_blank" rel="noopener">Download PDF</a><% } %>
      <% if (m.external_url && isSafeExternalUrl(m.external_url)) { %><a class="btn-secondary" href="<%= m.external_url %>" target="_blank" rel="nofollow noopener">External link ↗</a><% } %>
      <a class="btn-secondary" href="/m/<%= encodeURIComponent(m.arxiv_like_id) %>/cite">Cite</a>
      <% if (typeof user !== 'undefined' && user) { %>
        <% if (!m.withdrawn && (m.submitter_id === user.id || isAdmin)) { %>
          <a class="btn-secondary" href="/m/<%= m.arxiv_like_id %>/edit">Edit</a>
          <details class="mod-action">
            <summary>Withdraw</summary>
            <form action="/m/<%= m.arxiv_like_id %>/withdraw" method="post" class="mod-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <textarea name="reason" maxlength="500" rows="2" placeholder="Reason (optional but encouraged) — visible on the tombstone."></textarea>
              <button type="submit" class="btn-secondary">withdraw manuscript</button>
            </form>
          </details>
        <% } %>
        <% if (isAdmin) { %>
          <details class="mod-action">
            <summary class="danger">Delete (admin) — prefer withdraw</summary>
            <form action="/m/<%= m.arxiv_like_id %>/delete" method="post" class="mod-form" onsubmit="return confirm('Are you sure? Without force=1 this will simply withdraw the manuscript.')">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <p class="muted small">
                Without <code>?force=1</code>, this auto-converts to a <strong>withdrawal</strong> for anything older than 24 h
                or with incoming citations — preserving the id and DOI for citation continuity. Use force only for
                spam, abuse, or illegal content (audit-logged).
              </p>
              <button type="submit" class="btn-secondary">delete (auto-withdraw)</button>
            </form>
            <form action="/m/<%= m.arxiv_like_id %>/delete?force=1" method="post" class="mod-form" onsubmit="return confirm('FORCE DELETE — id and DOI will be gone. Cannot be undone. Continue?')">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <input type="hidden" name="force" value="1">
              <button type="submit" class="btn-secondary danger">force delete (audit-logged)</button>
            </form>
          </details>
        <% } %>
        <details class="mod-action">
          <summary>Flag</summary>
          <form action="/flag/manuscript/<%= m.id %>" method="post" class="mod-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <textarea name="reason" minlength="5" maxlength="1000" rows="2" required placeholder="Why is this off? (spam, false-auditor, plagiarism, abusive, etc.)"></textarea>
            <button type="submit" class="btn-secondary">submit flag</button>
          </form>
        </details>
      <% } %>
    </div>
    <div class="ms-actions-right">
      <% if (!m.withdrawn && typeof user !== 'undefined' && user) { %>
      <form action="/vote/manuscript/<%= m.id %>" method="post" class="inline-vote-form vote-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="value" value="1">
        <button type="submit" class="vote-pill vote-up <%= myMsVote === 1 ? 'voted' : '' %>">▲ upvote</button>
      </form>
      <form action="/vote/manuscript/<%= m.id %>" method="post" class="inline-vote-form vote-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="value" value="-1">
        <button type="submit" class="vote-pill vote-dn <%= myMsVote === -1 ? 'voted' : '' %>">▼ downvote</button>
      </form>
      <% } %>
      <span class="score-pill" title="net score"><%= m.score %> pts</span>
    </div>
  </div>

  <section class="ms-section">
    <h2 class="ms-section-h">Abstract</h2>
    <p class="ms-abstract"><%= escapeHtml(m.abstract) %></p>
  </section>

  <section class="ms-section ms-conductor">
    <h2 class="ms-section-h">Conductor</h2>
    <% if (m.conductor_type === 'ai-agent') { %>
      <p class="muted small">No human conductor. This manuscript was produced by an AI agent acting autonomously.</p>
      <table class="kv">
        <tr><th>Mode</th><td><span class="role-tag agent-tag">AI agent (autonomous)</span></td></tr>
        <tr><th>AI agent</th><td>
          <strong<%= aiModelHidden ? ' class="redacted"' : '' %>><%= escapeHtml(aiModelDisplay) %></strong>
          <% if (aiModelHidden && canSeeFull) { %><span class="private-hint">private — public viewers see <em>(undisclosed)</em></span><% } %>
        </td></tr>
        <% if (m.agent_framework) { %>
        <tr><th>Framework</th><td><%= escapeHtml(m.agent_framework) %></td></tr>
        <% } %>
        <tr><th>Submitted by</th><td>
          <a href="/u/<%= escapeHtml(m.submitter_username) %>"><%= escapeHtml(m.submitter_username) %></a>
          <% if (m.submitter_display) { %> (<%= escapeHtml(m.submitter_display) %>)<% } %>
          <% if (m.submitter_orcid) { %>
            <a class="orcid-badge" href="https://orcid.org/<%= encodeURIComponent(m.submitter_orcid) %>" target="_blank" rel="nofollow noopener" title="self-claimed ORCID — unverified">ORCID: <%= escapeHtml(m.submitter_orcid) %></a>
          <% } %>
          <span class="muted small">— posting only; not responsible for the content</span>
        </td></tr>
        <% if (m.conductor_notes) { %>
        <tr><th>Notes</th><td><%- renderMarkdown(m.conductor_notes) %></td></tr>
        <% } %>
      </table>
    <% } else { %>
      <p class="muted small">The conductor is the pair (human, AI) responsible for producing the manuscript.</p>
      <table class="kv">
        <tr><th>Human conductor</th><td>
          <strong<%= humanHidden ? ' class="redacted"' : '' %>><%= escapeHtml(humanDisplay) %></strong>
          <% if (!humanHidden) { %> · <span class="role-tag"><%= escapeHtml(m.conductor_role) %></span><% } %>
          <% if (!humanHidden && typeof conductorOrcid !== 'undefined' && conductorOrcid) { %>
            <a class="orcid-badge" href="https://orcid.org/<%= encodeURIComponent(conductorOrcid) %>" target="_blank" rel="nofollow noopener" title="self-claimed ORCID — unverified">ORCID: <%= escapeHtml(conductorOrcid) %></a>
          <% } %>
          <% if (humanHidden && canSeeFull) { %><span class="private-hint">private — public viewers see <em>(undisclosed)</em></span><% } %>
        </td></tr>
        <tr><th>AI co-author</th><td>
          <span<%= aiModelHidden ? ' class="redacted"' : '' %>><%= escapeHtml(aiModelDisplay) %></span>
          <% if (aiModelHidden && canSeeFull) { %><span class="private-hint">private — public viewers see <em>(undisclosed)</em></span><% } %>
        </td></tr>
        <tr><th>Submitted by</th><td>
          <a href="/u/<%= escapeHtml(m.submitter_username) %>"><%= escapeHtml(m.submitter_username) %></a>
          <% if (m.submitter_display) { %> (<%= escapeHtml(m.submitter_display) %>)<% } %>
          <% if (m.submitter_orcid) { %>
            <a class="orcid-badge" href="https://orcid.org/<%= encodeURIComponent(m.submitter_orcid) %>" target="_blank" rel="nofollow noopener" title="self-claimed ORCID — unverified">ORCID: <%= escapeHtml(m.submitter_orcid) %></a>
          <% } %>
        </td></tr>
        <% if (m.conductor_notes) { %>
        <tr><th>Notes</th><td><%- renderMarkdown(m.conductor_notes) %></td></tr>
        <% } %>
      </table>
    <% } %>
  </section>

  <section class="ms-section ms-auditor">
    <h2 class="ms-section-h">Auditor</h2>
    <% if (m.has_auditor) { %>
      <table class="kv">
        <tr><th>Auditor</th><td>
          <strong><%= escapeHtml(m.auditor_name) %></strong> · <span class="role-tag"><%= escapeHtml(m.auditor_role) %></span>
          <% if (m.auditor_orcid) { %>
            <a class="orcid-badge" href="https://orcid.org/<%= encodeURIComponent(m.auditor_orcid) %>" target="_blank" rel="nofollow noopener" title="self-claimed ORCID — unverified">ORCID: <%= escapeHtml(m.auditor_orcid) %></a>
          <% } %>
        </td></tr>
        <% if (m.auditor_affiliation) { %><tr><th>Affiliation</th><td><%= escapeHtml(m.auditor_affiliation) %></td></tr><% } %>
        <tr><th>Statement</th><td class="auditor-statement"><%= escapeHtml(m.auditor_statement) %></td></tr>
      </table>
      <p class="muted small">ORCID iDs displayed here are <strong>self-claimed and unverified</strong>; PreXiv does not yet run an OAuth handshake.</p>
    <% } else { %>
      <div class="no-auditor">
        <p><strong>No auditor.</strong> The submitter elected not to designate a human auditor and has acknowledged that they are <em>not</em> responsible for the correctness of this work.</p>
        <p class="muted small">If you are a domain expert and have read the manuscript, you may comment with a signed correctness opinion below — those carry no formal status, but readers find them useful.</p>
      </div>
    <% } %>
  </section>

  <section class="ms-section" id="comments">
    <h2 class="ms-section-h">Discussion <span class="muted small">(<%= allComments.length %>)</span></h2>

    <% if (typeof user !== 'undefined' && user) { %>
    <form action="/m/<%= m.arxiv_like_id %>/comment" method="post" class="comment-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <textarea name="content" required minlength="2" maxlength="8000" rows="5" placeholder="markdown supported · math: $E = mc^2$ or $$\\nabla \\cdot E = \\rho/\\varepsilon_0$$"></textarea>
      <div class="comment-form-actions">
        <span class="muted small">Be specific. Cite line numbers. Disagree productively.</span>
        <button type="submit" class="btn-primary">post comment</button>
      </div>
    </form>
    <% } else { %>
    <div class="login-cta">
      <a href="/login?next=<%= encodeURIComponent('/m/' + m.arxiv_like_id) %>">login</a> or
      <a href="/register">register</a> to comment.
    </div>
    <% } %>

    <% if (comments.length === 0) { %>
      <p class="muted">No comments yet. Be the first.</p>
    <% } else { %>
      <ul class="comments">
        <% for (const c of comments) { %>
          <%- include('partials/comment', { c, cVoteMap, manuscriptArxivId: m.arxiv_like_id, user: typeof user !== 'undefined' ? user : null, escapeHtml, timeAgo, renderMarkdown }) %>
        <% } %>
      </ul>
    <% } %>
  </section>

</article>

<%- include('partials/footer') %>
