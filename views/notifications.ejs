<% const pageTitle = 'notifications' %>
<%- include('partials/header', { pageTitle }) %>

<div class="page-header">
  <h1>Notifications</h1>
  <p class="muted small">Replies to your manuscripts and your comments. Unseen first; oldest first within unseen.</p>
</div>

<% const unseen = items.filter(i => !i.seen); %>

<% if (unseen.length) { %>
<form action="/me/notifications/mark-read" method="post" class="inline-form notif-mark-all-form">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
  <input type="hidden" name="all" value="1">
  <button type="submit" class="btn-secondary">Mark all read (<%= unseen.length %>)</button>
</form>
<% } %>

<% if (items.length === 0) { %>
  <div class="empty">
    <p>No notifications yet.</p>
    <p class="muted small">When someone comments on your manuscript or replies to one of your comments, you'll see it here.</p>
  </div>
<% } else { %>
  <ul class="notif-list">
    <% for (const n of items) { %>
      <%
        let summary = '';
        let href = n.arxiv_like_id ? '/m/' + encodeURIComponent(n.arxiv_like_id) : '/';
        if (n.comment_id) href += '#c' + n.comment_id;
        const actor = n.actor_username ? '@' + n.actor_username : 'someone';
        if (n.kind === 'comment_on_my_manuscript') {
          summary = actor + ' commented on your manuscript';
        } else if (n.kind === 'reply_to_my_comment') {
          summary = actor + ' replied to your comment';
        } else if (n.kind === 'vote_on_my_manuscript') {
          summary = actor + ' voted on your manuscript';
        } else if (n.kind === 'flag_resolved') {
          summary = 'Your flag was resolved';
        } else {
          summary = n.kind;
        }
      %>
      <li class="notif-row <%= n.seen ? 'seen' : 'unseen' %>" id="n<%= n.id %>">
        <div class="notif-body">
          <a class="notif-link" href="<%= href %>"><%= summary %></a>
          <% if (n.manuscript_title) { %>
            <span class="muted">— <em><%= escapeHtml(n.manuscript_title) %></em></span>
          <% } %>
        </div>
        <div class="notif-meta">
          <span class="muted small"><%= timeAgo(n.created_at) %></span>
          <% if (!n.seen) { %>
            <form action="/me/notifications/mark-read" method="post" class="inline-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <input type="hidden" name="ids" value="<%= n.id %>">
              <button type="submit" class="link-button">mark read</button>
            </form>
          <% } %>
        </div>
      </li>
    <% } %>
  </ul>
<% } %>

<%- include('partials/footer') %>
