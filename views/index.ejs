<% const pageTitle = mode === 'category' ? categoryMeta.id + ' — ' + categoryMeta.name :
                     mode === 'new' ? 'newest' :
                     mode === 'top' ? 'top' :
                     mode === 'audited' ? 'audited' : 'ranked'; %>
<%- include('partials/header', { pageTitle }) %>

<% if (mode === 'category') { %>
  <div class="page-header">
    <h1 class="cat-h1"><%= categoryMeta.id %> <span class="cat-h1-name"><%= categoryMeta.name %></span></h1>
    <p class="muted">All manuscripts categorized as <code><%= categoryMeta.id %></code>, newest first.</p>
  </div>
<% } else if (mode === 'audited') { %>
  <div class="page-header">
    <h1>Audited manuscripts</h1>
    <p class="muted">Only manuscripts with a named human auditor who has signed a correctness statement.</p>
  </div>
<% } %>

<% if (manuscripts.length === 0) { %>
  <div class="empty">
    <p>No manuscripts here yet.</p>
    <p><a href="/submit" class="btn-primary">Be the first to submit one →</a></p>
  </div>
<% } else { %>
<ol class="ms-list">
  <% for (let i = 0; i < manuscripts.length; i++) { const m = manuscripts[i]; const rank = (page - 1) * per + i + 1; %>
    <%- include('partials/manuscript_row', { m, rank, voteMap, CATEGORIES, escapeHtml, timeAgo, isSafeExternalUrl }) %>
  <% } %>
</ol>

<nav class="pagination">
  <% if (page > 1) { %>
    <a href="?page=<%= page - 1 %>">← previous</a>
  <% } %>
  <span class="muted">page <%= page %></span>
  <% if (manuscripts.length === per) { %>
    <a href="?page=<%= page + 1 %>">next →</a>
  <% } %>
</nav>
<% } %>

<%- include('partials/footer') %>
