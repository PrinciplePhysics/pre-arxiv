<% const pageTitle = 'edit profile' %>
<%- include('partials/header', { pageTitle }) %>

<div class="page-header">
  <h1>Edit profile</h1>
  <p class="muted">Tweak your public-facing display fields. Changes here also apply to past and future submissions where you appear as the submitter.</p>
</div>

<% if (errors && errors.length) { %>
<div class="form-errors">
  <strong>Please fix the following:</strong>
  <ul><% for (const e of errors) { %><li><%= e %></li><% } %></ul>
</div>
<% } %>

<form action="/me/edit" method="post" class="submit-form">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">

  <section class="form-section">
    <h2>Display</h2>

    <label>
      <span class="label-text">Display name</span>
      <input type="text" name="display_name" maxlength="200" value="<%= escapeHtml(values.display_name || '') %>" placeholder="Jane Doe">
      <span class="hint">Optional. Shown alongside your username on manuscripts and comments.</span>
    </label>

    <label>
      <span class="label-text">Affiliation</span>
      <input type="text" name="affiliation" maxlength="200" value="<%= escapeHtml(values.affiliation || '') %>" placeholder="MIT — Lab for Plausible Theorems">
      <span class="hint">Free-form. Where (or if) you do this work.</span>
    </label>

    <label>
      <span class="label-text">Bio</span>
      <textarea name="bio" maxlength="2000" rows="4" placeholder="Optional. A few sentences about yourself."><%= escapeHtml(values.bio || '') %></textarea>
    </label>
  </section>

  <div class="form-submit">
    <button type="submit" class="btn-primary big">Save changes</button>
    <a class="btn-secondary" href="/u/<%= encodeURIComponent(user.username) %>">Cancel</a>
  </div>
</form>

<%- include('partials/footer') %>
