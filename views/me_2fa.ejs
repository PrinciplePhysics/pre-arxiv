<% const pageTitle = 'two-factor authentication' %>
<%- include('partials/header', { pageTitle }) %>

<article class="prose">
  <div class="page-header">
    <h1>Two-factor authentication</h1>
    <p class="muted">PreXiv's web sign-in supports a TOTP second factor. Add any RFC 6238 authenticator (Google Authenticator, 1Password, Authy, Aegis, Bitwarden, etc.) — codes rotate every 30 seconds.</p>
  </div>

  <% if (errors && errors.length) { %>
    <div class="form-errors"><ul><% for (const e of errors) { %><li><%= e %></li><% } %></ul></div>
  <% } %>

  <% if (totpEnabled) { %>
    <section class="form-section">
      <h2>Status: <strong>enabled</strong></h2>
      <p>You are protected. After password login, the site will ask for a 6-digit code from your authenticator before completing sign-in.</p>
      <p class="muted small">The API surface (<code>/api/v1/login</code>) uses a separate convention; see the API page for details.</p>
    </section>

    <section class="form-section">
      <h2>Disable 2FA</h2>
      <p>Confirm with the current 6-digit code from your authenticator.</p>
      <form action="/me/2fa/disable" method="post">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <label>
          <span class="label-text">6-digit code</span>
          <input type="text" name="code" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" required autocomplete="one-time-code">
        </label>
        <button type="submit" class="btn-secondary danger">disable 2FA</button>
      </form>
    </section>
  <% } else if (pending) { %>
    <section class="form-section">
      <h2>Step 1 — scan or paste the secret</h2>
      <p>This secret is unique to your account. Add it to your authenticator, then enter the 6-digit code it shows.</p>

      <p>
        <strong>Secret (base32):</strong>
        <code class="mono"><%= escapeHtml(pending.secret) %></code>
      </p>

      <p>
        <strong>otpauth URI</strong> (most authenticators accept this directly):<br>
        <a href="<%= pending.otpauth %>"><%= escapeHtml(pending.otpauth) %></a>
      </p>

      <%# Inline ASCII-grid "QR-like" hint. We don't have a QR library so we
          render the otpauth string as a raw <code> block; users can paste it
          into their authenticator's "enter setup key" flow, or scan via QR if
          they generate one client-side. %>
      <details>
        <summary>Show raw otpauth URI as a code block (for clipboard / external QR generators)</summary>
        <pre><code><%= escapeHtml(pending.otpauth) %></code></pre>
      </details>
    </section>

    <section class="form-section">
      <h2>Step 2 — verify</h2>
      <p>Enter the 6-digit code your authenticator currently shows.</p>
      <form action="/me/2fa/verify" method="post">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <label>
          <span class="label-text">6-digit code</span>
          <input type="text" name="code" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" required autocomplete="one-time-code" autofocus>
        </label>
        <button type="submit" class="btn-primary">verify and enable</button>
      </form>
    </section>

    <section class="form-section">
      <p class="muted small">If you close this page before verifying, the pending secret is discarded. Just hit "set up 2FA" again to generate a fresh one.</p>
    </section>
  <% } else { %>
    <section class="form-section">
      <h2>Status: <strong>not enabled</strong></h2>
      <p>Set up an authenticator-app second factor. We will show you a fresh secret and an <code>otpauth://</code> URI; once your authenticator gives you a 6-digit code that matches, 2FA is on.</p>
      <form action="/me/2fa" method="post">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="btn-primary">set up 2FA</button>
      </form>
    </section>
  <% } %>
</article>

<%- include('partials/footer') %>
