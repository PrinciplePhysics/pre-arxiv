<% const pageTitle = 'login' %>
<%- include('partials/header', { pageTitle }) %>

<div class="auth-card">
  <h1>Log in</h1>
  <% if (errors && errors.length) { %>
  <div class="form-errors"><ul><% for (const e of errors) { %><li><%= e %></li><% } %></ul></div>
  <% } %>
  <form action="/login" method="post">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <input type="hidden" name="next" value="<%= escapeHtml(next || '/') %>">
    <label><span class="label-text">Username or email</span>
      <input type="text" name="username" required value="<%= escapeHtml((values && values.username) || '') %>" autofocus>
    </label>
    <label><span class="label-text">Password</span>
      <input type="password" name="password" required>
    </label>
    <button type="submit" class="btn-primary">log in</button>
  </form>
  <p class="muted small">No account? <a href="/register">Register</a>. Forgot your password? <a href="/forgot">Reset it</a>.</p>
</div>

<%- include('partials/footer') %>
