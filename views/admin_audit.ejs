<% const pageTitle = 'admin · audit log' %>
<%- include('partials/header', { pageTitle }) %>

<div class="page-header">
  <h1>Audit log</h1>
  <p class="muted">Privileged actions: manuscript delete, admin withdraw, admin comment delete, flag resolve, token revoke, 2FA enable/disable. Showing newest first.</p>
  <p class="muted small">Total entries: <%= total %></p>
</div>

<% if (!entries.length) { %>
  <p class="muted">No audit entries yet.</p>
<% } else { %>
<table class="kv">
  <thead>
    <tr>
      <th>When</th>
      <th>Actor</th>
      <th>Action</th>
      <th>Target</th>
      <th>Detail</th>
      <th>IP</th>
    </tr>
  </thead>
  <tbody>
    <% for (const e of entries) { %>
    <tr>
      <td class="muted small"><%= timeAgo(e.created_at) %></td>
      <td>
        <% if (e.actor_username) { %>
          <a href="/u/<%= escapeHtml(e.actor_username) %>"><%= escapeHtml(e.actor_username) %></a>
        <% } else { %>
          <span class="muted">(deleted user)</span>
        <% } %>
      </td>
      <td><code><%= escapeHtml(e.action) %></code></td>
      <td>
        <% if (e.target_type) { %>
          <code><%= escapeHtml(e.target_type) %><% if (e.target_id != null) { %>#<%= e.target_id %><% } %></code>
        <% } else { %>
          <span class="muted">—</span>
        <% } %>
      </td>
      <td class="small">
        <% if (e.detail) { %><%= escapeHtml(e.detail) %><% } else { %><span class="muted">—</span><% } %>
      </td>
      <td class="muted small mono">
        <% if (e.ip) { %><%= escapeHtml(e.ip) %><% } else { %>—<% } %>
      </td>
    </tr>
    <% } %>
  </tbody>
</table>

<nav class="pager">
  <% if (page > 1) { %><a href="/admin/audit?page=<%= page - 1 %>">← newer</a><% } %>
  <% if (entries.length === per) { %><a href="/admin/audit?page=<%= page + 1 %>">older →</a><% } %>
</nav>
<% } %>

<%- include('partials/footer') %>
