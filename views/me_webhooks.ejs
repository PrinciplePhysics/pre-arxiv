<% const pageTitle = 'webhooks' %>
<%- include('partials/header', { pageTitle }) %>

<article class="prose">
  <div class="page-header">
    <h1>Webhooks</h1>
    <p class="muted">Subscribe an automated agent to PreXiv events. We POST a signed JSON envelope to your URL whenever something you care about happens.</p>
  </div>

  <% if (errors && errors.length) { %>
    <div class="form-errors"><ul><% for (const e of errors) { %><li><%= e %></li><% } %></ul></div>
  <% } %>

  <% if (justCreated) { %>
    <section class="form-section just-created-token">
      <h2>New webhook created</h2>
      <p><strong>Copy the secret now.</strong> It will not be shown again. Use it to verify the <code>X-PreXiv-Signature</code> header on incoming deliveries (HMAC-SHA256 of the request body, hex, prefixed with <code>sha256=</code>).</p>
      <p>
        <input type="text" readonly value="<%= escapeHtml(justCreated.secret) %>" class="mono token-display" onclick="this.select();">
      </p>
      <p class="muted small">URL: <code><%= escapeHtml(justCreated.url) %></code> · events: <code><%= escapeHtml(justCreated.events.join(', ')) %></code></p>
    </section>
  <% } %>

  <section class="form-section">
    <h2>Create a webhook</h2>
    <form action="/me/webhooks" method="post">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label>
        <span class="label-text">Delivery URL <span class="muted">(must be HTTPS in production; HTTP allowed in dev)</span></span>
        <input type="url" name="url" required placeholder="https://example.com/hooks/prexiv">
      </label>
      <label>
        <span class="label-text">Description <span class="muted">(optional, for your records)</span></span>
        <input type="text" name="description" maxlength="200" placeholder="e.g. 'autosubmit-bot dev'">
      </label>
      <fieldset class="ctype-section">
        <legend><strong>Events to subscribe to</strong></legend>
        <% for (const ev of supportedEvents) { %>
          <label style="display:block; margin: 4px 0;">
            <input type="checkbox" name="events" value="<%= ev %>"> <code><%= ev %></code>
          </label>
        <% } %>
      </fieldset>
      <button type="submit" class="btn-primary">create webhook</button>
    </form>
  </section>

  <section class="form-section">
    <h2>Existing webhooks <span class="muted">(<%= webhooks.length %>)</span></h2>
    <% if (!webhooks.length) { %>
      <p class="muted">You haven't registered any webhooks.</p>
    <% } else { %>
    <table class="kv">
      <thead>
        <tr>
          <th>URL</th><th>Events</th><th>Status</th><th>Last delivery</th><th>Failures</th><th></th>
        </tr>
      </thead>
      <tbody>
        <% for (const w of webhooks) { %>
        <tr>
          <td>
            <code class="mono small"><%= escapeHtml(w.url) %></code>
            <% if (w.description) { %><div class="muted small"><%= escapeHtml(w.description) %></div><% } %>
          </td>
          <td>
            <% try { %>
              <% for (const ev of (JSON.parse(w.events) || [])) { %>
                <code class="small"><%= escapeHtml(ev) %></code><br>
              <% } %>
            <% } catch (_e) { %>
              <span class="muted small">(unreadable)</span>
            <% } %>
          </td>
          <td class="small"><%= w.active ? 'active' : 'paused' %></td>
          <td class="muted small"><%= w.last_attempt_at ? (timeAgo(w.last_attempt_at) + ' (' + (w.last_status || 0) + ')') : 'never' %></td>
          <td class="muted small"><%= w.failure_count %></td>
          <td>
            <form action="/me/webhooks/<%= w.id %>/ping" method="post" class="inline-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="btn-secondary small">ping</button>
            </form>
            <form action="/me/webhooks/<%= w.id %>/delete" method="post" class="inline-form" onsubmit="return confirm('Delete this webhook? Future events will not be delivered.')">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="btn-secondary danger small">delete</button>
            </form>
          </td>
        </tr>
        <% } %>
      </tbody>
    </table>
    <% } %>
  </section>

  <section class="form-section">
    <h2>Envelope &amp; signature</h2>
    <p>Every event POST has body</p>
    <pre><code>{
  "event":   "manuscript.created",
  "ts":      "2026-05-11T12:00:00.000Z",
  "payload": { ...event-specific fields... }
}</code></pre>
    <p>and header <code>X-PreXiv-Signature: sha256=&lt;hex&gt;</code>, where the hex is <code>HMAC_SHA256(secret, raw_body)</code>. Verify before trusting the payload — the URL is otherwise unauthenticated.</p>
    <p>Supported events: <% for (const ev of supportedEvents) { %><code><%= ev %></code> <% } %></p>
    <p class="muted small">After 5 consecutive non-2xx responses (or network errors / timeouts) we set the webhook to <em>paused</em> and notify you in-app. Re-create it once your endpoint is healthy.</p>
  </section>

  <section class="form-section">
    <h2>JSON API</h2>
    <p class="muted small">Same operations, Bearer-authenticated, no CSRF.</p>
    <table class="op-table">
      <thead><tr><th>Method</th><th>Path</th><th>Notes</th></tr></thead>
      <tbody>
        <tr><td><code class="method method-get">GET</code></td><td><code>/api/v1/me/webhooks</code></td><td>List your webhooks (no secrets).</td></tr>
        <tr><td><code class="method method-post">POST</code></td><td><code>/api/v1/me/webhooks</code></td><td>Body: <code>{ url, events, description? }</code>. Returns the secret once.</td></tr>
        <tr><td><code class="method method-delete">DELETE</code></td><td><code>/api/v1/me/webhooks/{id}</code></td><td>Permanently delete.</td></tr>
        <tr><td><code class="method method-post">POST</code></td><td><code>/api/v1/me/webhooks/{id}/ping</code></td><td>Fire a test event right now.</td></tr>
      </tbody>
    </table>
  </section>
</article>

<%- include('partials/footer') %>
