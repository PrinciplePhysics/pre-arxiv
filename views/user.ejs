<% const pageTitle = profile.username %>
<%- include('partials/header', { pageTitle }) %>

<div class="user-card">
  <h1><%= escapeHtml(profile.username) %></h1>
  <% if (profile.display_name) { %><div class="user-display"><%= escapeHtml(profile.display_name) %></div><% } %>
  <% if (profile.affiliation) { %><div class="user-affil muted"><%= escapeHtml(profile.affiliation) %></div><% } %>
  <div class="user-stats">
    <span><strong><%= profile.karma %></strong> karma</span>
    <span><strong><%= submissions.length %></strong> submission<%= submissions.length === 1 ? '' : 's' %></span>
    <span><strong><%= conductedAs.length %></strong> conducted</span>
    <span><strong><%= auditedCount %></strong> audited</span>
    <span class="muted">joined <%= timeAgo(profile.created_at) %></span>
  </div>
  <% if (profile.bio) { %><p class="user-bio"><%= escapeHtml(profile.bio) %></p><% } %>
</div>

<h2 class="user-h2">Submissions</h2>
<% if (submissions.length === 0) { %>
  <p class="muted">No submissions yet.</p>
<% } else { %>
  <ol class="ms-list">
    <% for (let i = 0; i < submissions.length; i++) { const m = submissions[i]; %>
      <%- include('partials/manuscript_row', { m, rank: i + 1, voteMap: {}, CATEGORIES, escapeHtml, timeAgo }) %>
    <% } %>
  </ol>
<% } %>

<%- include('partials/footer') %>
