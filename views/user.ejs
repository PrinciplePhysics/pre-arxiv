<% const pageTitle = profile.username %>
<% const _isFollowing = (typeof isFollowing !== 'undefined') ? !!isFollowing : false; %>
<% const _isSelf      = (typeof isSelf !== 'undefined') ? !!isSelf : false; %>
<% const _followerCount  = (typeof followerCount  !== 'undefined') ? followerCount  : 0; %>
<% const _followingCount = (typeof followingCount !== 'undefined') ? followingCount : 0; %>
<%- include('partials/header', { pageTitle }) %>

<div class="user-card">
  <div class="user-card-head">
    <div>
      <h1><%= escapeHtml(profile.username) %></h1>
      <% if (profile.display_name) { %><div class="user-display"><%= escapeHtml(profile.display_name) %></div><% } %>
      <% if (profile.affiliation) { %><div class="user-affil muted"><%= escapeHtml(profile.affiliation) %></div><% } %>
    </div>
    <div class="user-card-actions">
      <% if (typeof user !== 'undefined' && user) { %>
        <% if (_isSelf) { %>
          <a class="btn-secondary" href="/me/edit">Edit profile</a>
        <% } else if (_isFollowing) { %>
          <form action="/u/<%= encodeURIComponent(profile.username) %>/unfollow" method="post" class="inline-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="btn-secondary">Unfollow</button>
          </form>
        <% } else { %>
          <form action="/u/<%= encodeURIComponent(profile.username) %>/follow" method="post" class="inline-form">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="btn-primary">Follow</button>
          </form>
        <% } %>
      <% } %>
    </div>
  </div>
  <div class="user-stats">
    <span><strong><%= profile.karma %></strong> karma</span>
    <span><strong><%= submissions.length %></strong> submission<%= submissions.length === 1 ? '' : 's' %></span>
    <span><strong><%= conductedAs.length %></strong> conducted</span>
    <span><strong><%= auditedCount %></strong> audited</span>
    <span><strong><%= _followerCount %></strong> follower<%= _followerCount === 1 ? '' : 's' %></span>
    <span><strong><%= _followingCount %></strong> following</span>
    <span class="muted">joined <%= timeAgo(profile.created_at) %></span>
  </div>
  <% if (profile.bio) { %>
    <div class="user-bio"><%- renderMarkdown(profile.bio) %></div>
  <% } %>
</div>

<h2 class="user-h2">Submissions</h2>
<% if (submissions.length === 0) { %>
  <p class="muted">No submissions yet.</p>
<% } else { %>
  <ol class="ms-list">
    <% for (let i = 0; i < submissions.length; i++) { const m = submissions[i]; %>
      <%- include('partials/manuscript_row', { m, rank: i + 1, voteMap: {}, CATEGORIES, escapeHtml, timeAgo, isSafeExternalUrl }) %>
    <% } %>
  </ol>
<% } %>

<%- include('partials/footer') %>
