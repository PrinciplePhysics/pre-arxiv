<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' · pre-arxiv' : 'pre-arxiv — preprint of preprints' %></title>
  <meta name="description" content="pre-arxiv: a community archive of AI-authored, human-conducted manuscripts that have not yet passed rigorous human audit.">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css">
  <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.js"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/contrib/auto-render.min.js" onload="renderMathInElement(document.body, { delimiters: [{left:'$$',right:'$$',display:true},{left:'$',right:'$',display:false},{left:'\\\\(',right:'\\\\)',display:false},{left:'\\\\[',right:'\\\\]',display:true}], throwOnError: false });"></script>
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='10' fill='%23b8430a'/%3E%3Ctext x='50%25' y='56%25' text-anchor='middle' fill='white' font-family='Georgia,serif' font-size='30' font-weight='bold'%3E%CF%80%3C/text%3E%3C/svg%3E">
</head>
<body>
<header class="topbar">
  <div class="topbar-inner">
    <a class="brand" href="/">
      <span class="brand-mark">π</span>
      <span class="brand-name">pre-arxiv</span>
      <span class="brand-tagline">preprint of preprints</span>
    </a>
    <nav class="topnav">
      <a href="/"        class="<%= path === '/' ? 'on' : '' %>">ranked</a>
      <a href="/new"     class="<%= path === '/new' ? 'on' : '' %>">new</a>
      <a href="/top"     class="<%= path === '/top' ? 'on' : '' %>">top</a>
      <a href="/audited" class="<%= path === '/audited' ? 'on' : '' %>">audited</a>
      <a href="/browse"  class="<%= path && path.startsWith('/browse') ? 'on' : '' %>">browse</a>
      <a href="/submit"  class="<%= path === '/submit' ? 'on submit-link' : 'submit-link' %>">submit</a>
      <a href="/about"   class="<%= path === '/about' ? 'on' : '' %>">about</a>
      <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
      <a href="/admin"   class="<%= path === '/admin' ? 'on admin-link' : 'admin-link' %>">admin</a>
      <% } %>
    </nav>
    <form class="searchbox" action="/search" method="get">
      <input type="search" name="q" placeholder="search title, author, id…" value="<%= escapeHtml((currentQuery && currentQuery.q) || '') %>">
    </form>
    <div class="userbox">
      <% if (user) { %>
        <a href="/u/<%= escapeHtml(user.username) %>" class="me"><%= escapeHtml(user.username) %></a>
        <span class="karma" title="karma">(<%= user.karma %>)</span>
        <form action="/logout" method="post" class="logout-form"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button type="submit">logout</button></form>
      <% } else { %>
        <a href="/login">login</a>
        <span class="sep">·</span>
        <a href="/register">register</a>
      <% } %>
    </div>
  </div>
</header>

<% if (flash) { %>
  <div class="flash flash-<%= flash.type %>"><%= flash.msg %></div>
<% } %>

<main class="container">
