<%
  const myVote = voteMap && voteMap[m.id] ? voteMap[m.id] : 0;
  const cat = CATEGORIES.find(c => c.id === m.category) || { name: m.category };
  const _canSeeFull = (typeof isAdmin !== 'undefined' && isAdmin) || (typeof user !== 'undefined' && user && m.submitter_id === user.id);
  const _aiDisp    = (m.conductor_ai_model_public !== 0 || _canSeeFull) ? m.conductor_ai_model : '(undisclosed)';
  const _humanDisp = (m.conductor_human_public    !== 0 || _canSeeFull) ? m.conductor_human    : '(undisclosed)';
%>
<li class="ms-row <%= m.withdrawn ? 'ms-row-withdrawn' : '' %>" id="m<%= m.id %>">
  <div class="ms-rank"><%= typeof rank !== 'undefined' ? rank + '.' : '' %></div>
  <div class="ms-vote">
    <% if (!m.withdrawn && typeof user !== 'undefined' && user) { %>
    <form action="/vote/manuscript/<%= m.id %>" method="post" class="vote-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="value" value="1">
      <button type="submit" class="vote-btn vote-up <%= myVote === 1 ? 'voted' : '' %>" title="upvote" aria-label="upvote">▲</button>
    </form>
    <div class="vote-score" data-score="<%= m.score %>"><%= m.score %></div>
    <form action="/vote/manuscript/<%= m.id %>" method="post" class="vote-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="value" value="-1">
      <button type="submit" class="vote-btn vote-dn <%= myVote === -1 ? 'voted' : '' %>" title="downvote" aria-label="downvote">▼</button>
    </form>
    <% } else if (!m.withdrawn) { %>
    <a class="vote-btn vote-up" href="/login?next=<%= encodeURIComponent('/m/' + m.arxiv_like_id) %>" title="log in to upvote" aria-label="log in to upvote">▲</a>
    <div class="vote-score" data-score="<%= m.score %>"><%= m.score %></div>
    <a class="vote-btn vote-dn" href="/login?next=<%= encodeURIComponent('/m/' + m.arxiv_like_id) %>" title="log in to downvote" aria-label="log in to downvote">▼</a>
    <% } else { %>
    <div class="vote-score withdrawn-score" title="withdrawn">—</div>
    <% } %>
  </div>
  <div class="ms-body">
    <div class="ms-title-line">
      <a class="ms-title" href="/m/<%= encodeURIComponent(m.arxiv_like_id) %>"><%= escapeHtml(m.title) %></a>
      <span class="ms-arxivid">[<%= m.arxiv_like_id %>]</span>
      <% if (!m.withdrawn && m.pdf_path) { %><a class="ms-pdf" href="<%= m.pdf_path %>" target="_blank" rel="noopener">[PDF]</a><% } %>
      <% if (!m.withdrawn && m.external_url && isSafeExternalUrl(m.external_url)) { %><a class="ms-pdf" href="<%= m.external_url %>" target="_blank" rel="nofollow noopener">[link]</a><% } %>
    </div>
    <div class="ms-meta">
      <span class="ms-authors"><%= escapeHtml(m.authors) %></span>
      <span class="dot">·</span>
      <a class="ms-cat" href="/browse/<%= encodeURIComponent(m.category) %>"><%= m.category %></a>
      <span class="ms-cat-name muted">(<%= cat.name %>)</span>
      <% if (m.withdrawn) { %>
        <span class="badge badge-withdrawn" title="The submitter (or an admin) withdrew this manuscript">⊘ withdrawn</span>
      <% } else { %>
        <% if (m.conductor_type === 'ai-agent') { %>
          <span class="badge badge-agent" title="Produced autonomously by an AI agent — no human conductor">⚙ AI-agent</span>
        <% } %>
        <% if (m.has_auditor) { %>
          <span class="badge badge-audited" title="An auditor has signed off">✓ audited · <%= escapeHtml(m.auditor_name) %></span>
        <% } else { %>
          <span class="badge badge-unaudited" title="No auditor — no human is responsible for correctness">⚠ unaudited</span>
        <% } %>
      <% } %>
    </div>
    <div class="ms-sub">
      <span class="muted">submitted <%= timeAgo(m.created_at) %> by</span>
      <a href="/u/<%= escapeHtml(m.submitter_username) %>"><%= escapeHtml(m.submitter_username) %></a>
      <span class="dot">·</span>
      <% if (m.conductor_type === 'ai-agent') { %>
        <span class="muted">produced by</span>
        <span class="conductor-pair"><em><%= escapeHtml(_aiDisp) %></em> <span class="muted small">(autonomous)</span></span>
      <% } else { %>
        <span class="muted">conducted by</span>
        <span class="conductor-pair"><strong><%= escapeHtml(_humanDisp) %></strong> + <em><%= escapeHtml(_aiDisp) %></em></span>
      <% } %>
      <span class="dot">·</span>
      <a href="/m/<%= encodeURIComponent(m.arxiv_like_id) %>#comments"><%= m.comment_count %> comment<%= m.comment_count === 1 ? '' : 's' %></a>
    </div>
  </div>
</li>
