<%# ─── Cookie consent banner. Only renders when the prexiv_cookie_consent
     cookie is absent. The "OK" button sets it for one year via document.cookie
     and removes the banner. Purely informational; never blocks the page. ─── %>
<% if (!(typeof cookieConsentSet !== 'undefined' && cookieConsentSet)) { %>
<div id="prexiv-cookie-banner" class="cookie-banner" role="region" aria-label="Cookie notice">
  <div class="cookie-banner-inner">
    <span>PreXiv stores a session cookie when you log in and a theme-preference cookie. No tracking.</span>
    <span class="cookie-banner-actions">
      <a href="/privacy" class="cookie-banner-link">Privacy policy</a>
      <button type="button" id="prexiv-cookie-ok" class="cookie-banner-ok">OK</button>
    </span>
  </div>
</div>
<script>
  (function () {
    var btn = document.getElementById('prexiv-cookie-ok');
    var banner = document.getElementById('prexiv-cookie-banner');
    if (!btn || !banner) return;
    btn.addEventListener('click', function () {
      // 1 year, lax, root path. SameSite=Lax keeps it from leaking on
      // cross-site navigations while still working on top-level requests.
      document.cookie = 'prexiv_cookie_consent=1; Max-Age=31536000; Path=/; SameSite=Lax';
      banner.parentNode.removeChild(banner);
    });
  }());
</script>
<% } %>

<script src="/js/app.js"></script>
