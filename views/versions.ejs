<% const pageTitle = 'versions · ' + m.title %>
<%- include('partials/header', { pageTitle }) %>

<div class="page-header">
  <h1>Version history</h1>
  <p class="muted">
    <a href="/m/<%= encodeURIComponent(m.arxiv_like_id) %>"><%= m.arxiv_like_id %></a>
    — <%= escapeHtml(m.title) %>
  </p>
  <p class="muted small">
    Each entry below is a snapshot of the manuscript as it stood <em>before</em> a subsequent edit.
    Version 1 is the original submission. The current live page corresponds to version <%= currentVersion %>.
  </p>
</div>

<% if (!versions.length) { %>
  <p class="muted">No version history yet.</p>
<% } else { %>
  <ol class="ms-list version-list">
    <% for (let idx = 0; idx < versions.length; idx++) { const v = versions[idx]; %>
      <li class="version-row" id="v<%= v.version %>">
        <div class="version-head">
          <strong>v<%= v.version %></strong>
          <span class="muted small">snapshotted <%= timeAgo(v.created_at) %></span>
          <% if (v.version === currentVersion) { %>
            <span class="badge">current</span>
          <% } %>
        </div>
        <% if (v.diff_summary) { %>
          <div class="version-summary">
            <strong>What changed:</strong> <%= escapeHtml(v.diff_summary) %>
          </div>
        <% } else { %>
          <div class="version-summary muted small">No change summary recorded.</div>
        <% } %>
        <div class="version-title muted">Title at this point: <em><%= escapeHtml(v.title) %></em></div>
        <% const prev = versions[idx + 1]; if (prev) { %>
          <details class="mod-action">
            <summary>diff vs v<%= prev.version %></summary>
            <pre class="diff-pre"><%= escapeHtml(diffs[v.version] || '(identical)') %></pre>
          </details>
        <% } else { %>
          <span class="muted small">First snapshot — nothing to diff against.</span>
        <% } %>
      </li>
    <% } %>
  </ol>
<% } %>

<%- include('partials/footer') %>
