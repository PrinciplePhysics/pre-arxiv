<% const pageTitle = 'forgot password' %>
<%- include('partials/header', { pageTitle }) %>

<div class="auth-card">
  <h1>Reset your password</h1>
  <p class="muted small">Enter the email you registered with. If we recognize it, we'll send a one-time reset link valid for one hour.</p>

  <% if (errors && errors.length) { %>
  <div class="form-errors"><ul><% for (const e of errors) { %><li><%= e %></li><% } %></ul></div>
  <% } %>

  <form action="/forgot" method="post">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label><span class="label-text">Email</span>
      <input type="email" name="email" required autofocus value="<%= escapeHtml((values && values.email) || '') %>">
    </label>
    <button type="submit" class="btn-primary">send reset link</button>
  </form>

  <% if (devLink) { %>
    <div class="dev-link-box">
      <strong>This server doesn't send email.</strong>
      Use this link directly:
      <p><a href="<%= devLink %>" class="dev-link"><%= devLink %></a></p>
    </div>
  <% } %>

  <p class="muted small" style="margin-top: 14px"><a href="/login">← back to login</a></p>
</div>

<%- include('partials/footer') %>
