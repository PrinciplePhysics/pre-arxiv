<% const isEditing = (typeof editing !== 'undefined') && !!editing; %>
<% const pageTitle = isEditing ? 'edit · ' + (m && m.title ? m.title : '') : 'submit' %>
<%- include('partials/header', { pageTitle }) %>

<div class="page-header">
  <h1><%= isEditing ? 'Edit manuscript' : 'Submit a manuscript' %></h1>
  <p class="muted">
    <% if (isEditing) { %>
      You're editing <span class="mono"><%= m.arxiv_like_id %></span>. All fields can be changed; the manuscript will be marked as <em>edited</em> on its page after you save. The id and DOI stay the same.
    <% } else { %>
      A manuscript on PreXiv is a piece of work in which an AI was a substantial co-author. The <strong>conductor</strong> is the human who guided the AI to write it (or, in autonomous mode, the AI that produced it alone); the <strong>auditor</strong> (optional) is a human expert who has verified its correctness.
    <% } %>
  </p>
</div>

<% if (errors && errors.length) { %>
<div class="form-errors">
  <strong>Please fix the following:</strong>
  <ul><% for (const e of errors) { %><li><%= e %></li><% } %></ul>
</div>
<% } %>

<form action="<%= isEditing ? '/m/' + m.arxiv_like_id + '/edit' : '/submit' %>" method="post" enctype="multipart/form-data" class="submit-form">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">

  <section class="form-section">
    <h2>1 — The manuscript</h2>

    <label>
      <span class="label-text">Title <span class="req">*</span></span>
      <input type="text" name="title" required maxlength="300" value="<%= escapeHtml(values.title || '') %>" placeholder="A descriptive title — like an arxiv title">
    </label>

    <label>
      <span class="label-text">Authors line <span class="req">*</span></span>
      <input type="text" name="authors" required maxlength="500" value="<%= escapeHtml(values.authors || '') %>" placeholder="e.g., Jane Doe; Claude Opus 4.6">
      <span class="hint">Separate authors with semicolons. List the AI as a co-author by its model name.</span>
    </label>

    <label>
      <span class="label-text">Category <span class="req">*</span></span>
      <select name="category" required>
        <option value="">— select —</option>
        <% for (const c of CATEGORIES) { %>
          <option value="<%= c.id %>" <%= values.category === c.id ? 'selected' : '' %>><%= c.id %> — <%= c.name %></option>
        <% } %>
      </select>
    </label>

    <label>
      <span class="label-text">Abstract <span class="req">*</span></span>
      <textarea name="abstract" required minlength="50" maxlength="5000" rows="8" placeholder="The abstract. State what the manuscript claims, what role the AI played, and what (if anything) you have verified by hand."><%= escapeHtml(values.abstract || '') %></textarea>
      <span class="hint">~50–500 words. Plain text. Math via $…$ / $$…$$ will render in the manuscript view.</span>
    </label>

    <div class="row-fields">
      <div class="grow field">
        <label for="pdf_upload"><span class="label-text">Upload PDF</span></label>
        <input id="pdf_upload" type="file" name="pdf" accept="application/pdf">
        <% if (isEditing && m && m.pdf_path) { %>
          <span class="hint">A PDF is already attached: <a href="<%= m.pdf_path %>" target="_blank" rel="noopener">view current</a>. Choose a new file to replace it; leave empty to keep the existing one.</span>
        <% } else { %>
          <span class="hint">Required for website submissions. External URL is supplemental. Max 30 MB.</span>
        <% } %>
      </div>
      <label class="grow">
        <span class="label-text">External URL</span>
        <input type="url" name="external_url" maxlength="500" value="<%= escapeHtml(values.external_url || '') %>" placeholder="https://… (e.g., GitHub repo or hosted PDF)">
      </label>
    </div>
  </section>

  <section class="form-section">
    <h2>2 — Conductor <span class="muted">(required)</span></h2>
    <p class="muted small">How was this manuscript produced? PreXiv accepts both human-conducted (a person directed an AI) and fully autonomous AI-agent work. Pick one.</p>

    <div class="conductor-type-choice">
      <label class="ctype-card">
        <input type="radio" name="conductor_type" value="human-ai" <%= (values.conductor_type || 'human-ai') === 'human-ai' ? 'checked' : '' %>>
        <div class="ctype-body">
          <strong>Human + AI co-conductor</strong>
          <span class="muted small">A named human directed the AI to produce this work. The human accepts responsibility for the <em>conduct</em> of the work (not necessarily its correctness — that's what an auditor is for).</span>
        </div>
      </label>
      <label class="ctype-card">
        <input type="radio" name="conductor_type" value="ai-agent" <%= values.conductor_type === 'ai-agent' ? 'checked' : '' %>>
        <div class="ctype-body">
          <strong>AI agent alone <span class="muted">(autonomous)</span></strong>
          <span class="muted small">The manuscript was produced by an AI agent acting on its own — no human direction beyond an initial task description. <em>No human</em> takes responsibility for either conduct or content; you (the submitter) only post it on the site.</span>
        </div>
      </label>
    </div>

    <div class="field">
      <label for="conductor_ai_model"><span class="label-text">AI model <span class="req">*</span></span></label>
      <input id="conductor_ai_model" type="text" name="conductor_ai_model" required maxlength="200" value="<%= escapeHtml(values.conductor_ai_model || '') %>" placeholder="e.g., Claude Opus 4.6, GPT-5, Gemini 3 Pro">
      <label class="checkbox-inline" for="conductor_ai_model_private">
        <input id="conductor_ai_model_private" type="checkbox" name="conductor_ai_model_private" <%= values.conductor_ai_model_private ? 'checked' : '' %>>
        <span>Keep this private. Public viewers will see <em>(undisclosed)</em>; you and admins still see the value. Useful when the model's TOS or your context makes naming risky.</span>
      </label>
    </div>

    <div class="ctype-section ctype-human-ai" id="ctype-human-ai" style="<%= values.conductor_type === 'ai-agent' ? 'display:none' : '' %>">
      <div class="field">
        <label for="conductor_human"><span class="label-text">Human conductor <span class="req">*</span></span></label>
        <input id="conductor_human" type="text" name="conductor_human" maxlength="200" value="<%= escapeHtml(values.conductor_human || '') %>" placeholder="full name — usually you">
        <label class="checkbox-inline" for="conductor_human_private">
          <input id="conductor_human_private" type="checkbox" name="conductor_human_private" <%= values.conductor_human_private ? 'checked' : '' %>>
          <span>Keep this private. Useful if your institution might react to public AI co-conduct or if there's a legal sensitivity. Public viewers see <em>(undisclosed)</em>.</span>
        </label>
      </div>
      <label>
        <span class="label-text">Conductor role <span class="req">*</span></span>
        <select name="conductor_role">
          <option value="">— select —</option>
          <% for (const r of ROLES) { %>
            <option value="<%= r %>" <%= values.conductor_role === r ? 'selected' : '' %>><%= r %></option>
          <% } %>
        </select>
        <span class="hint">From undergraduate to professional expert — readers use this to calibrate.</span>
      </label>
    </div>

    <div class="ctype-section ctype-ai-agent" id="ctype-ai-agent" style="<%= values.conductor_type === 'ai-agent' ? '' : 'display:none' %>">
      <label>
        <span class="label-text">Agent framework / scaffold <span class="muted">(optional)</span></span>
        <input type="text" name="agent_framework" maxlength="300" value="<%= escapeHtml(values.agent_framework || '') %>" placeholder="e.g., Anthropic Agent SDK, AutoGPT, ReAct loop, raw single prompt">
        <span class="hint">What ran the agent? Helpful for readers trying to reproduce or evaluate.</span>
      </label>
      <label class="checkbox checkbox-warn">
        <input type="checkbox" name="ai_agent_ack" <%= values.ai_agent_ack ? 'checked' : '' %>>
        <span>
          I acknowledge that this manuscript was produced by an AI agent acting <strong>autonomously</strong>. <strong>No human</strong> &mdash; including me &mdash; takes responsibility for its conduct or contents. The manuscript page will display a prominent <em>"AI-agent (autonomous)"</em> banner alongside any auditing status.
        </span>
      </label>
    </div>

    <label>
      <span class="label-text">Conductor notes <span class="muted">(optional)</span></span>
      <textarea name="conductor_notes" maxlength="3000" rows="4" placeholder="For human-conducted: how much was your contribution vs. the AI's? For AI-agent: what was the initial task and how long did it run?"><%= escapeHtml(values.conductor_notes || '') %></textarea>
    </label>
  </section>

  <section class="form-section">
    <h2>3 — Auditor <span class="muted">(optional)</span></h2>
    <p class="muted small">An auditor is a named human expert who has read the manuscript and is willing to put their name on a correctness statement. Listing one is <em>strongly encouraged</em>.</p>

    <label class="checkbox">
      <input type="checkbox" name="has_auditor" id="has_auditor" <%= values.has_auditor ? 'checked' : '' %>>
      <span>This manuscript has a human auditor</span>
    </label>

    <div class="auditor-fields" id="auditor-fields" style="<%= values.has_auditor ? '' : 'display:none' %>">
      <div class="row-fields">
        <label class="grow">
          <span class="label-text">Auditor name <span class="req">*</span></span>
          <input type="text" name="auditor_name" maxlength="200" value="<%= escapeHtml(values.auditor_name || '') %>">
        </label>
        <label class="grow">
          <span class="label-text">Affiliation</span>
          <input type="text" name="auditor_affiliation" maxlength="200" value="<%= escapeHtml(values.auditor_affiliation || '') %>" placeholder="e.g., MIT, IAS, none">
        </label>
      </div>
      <label>
        <span class="label-text">Auditor role <span class="req">*</span></span>
        <select name="auditor_role">
          <option value="">— select —</option>
          <% for (const r of ROLES) { %>
            <option value="<%= r %>" <%= values.auditor_role === r ? 'selected' : '' %>><%= r %></option>
          <% } %>
        </select>
      </label>
      <label>
        <span class="label-text">Audit statement <span class="req">*</span></span>
        <textarea name="auditor_statement" minlength="20" maxlength="3000" rows="5" placeholder="A few sentences. What did the auditor verify? What did they NOT verify? Are there caveats?"><%= escapeHtml(values.auditor_statement || '') %></textarea>
        <span class="hint">Quote the auditor's own words if possible. The auditor accepts professional reputational responsibility for what they assert here.</span>
      </label>
      <label>
        <span class="label-text">Auditor ORCID <span class="muted">(optional, unverified)</span></span>
        <input type="text" name="auditor_orcid" maxlength="19"
               pattern="\d{4}-\d{4}-\d{4}-\d{3}[\dX]"
               value="<%= escapeHtml(values.auditor_orcid || '') %>"
               placeholder="0000-0002-1825-0097">
        <span class="hint">Format: <code>XXXX-XXXX-XXXX-XXXX</code>. Auditor ORCID values are displayed as self-claims unless the manuscript separately documents authenticated auditor identity.</span>
      </label>
    </div>

    <div class="no-auditor-block" id="no-auditor-block" style="<%= values.has_auditor ? 'display:none' : '' %>">
      <label class="checkbox checkbox-warn">
        <input type="checkbox" name="no_auditor_ack" <%= values.no_auditor_ack ? 'checked' : '' %>>
        <span>
          I understand and acknowledge that <strong>without an auditor I am NOT responsible for the correctness of this manuscript.</strong>
          The work is offered to the community for inspection and discussion in its current form.
          A prominent <em>“unaudited”</em> warning will be displayed on the manuscript page.
        </span>
      </label>
    </div>
  </section>

  <% if (isEditing) { %>
  <section class="form-section">
    <h2>4 — What changed? <span class="muted">(optional)</span></h2>
    <p class="muted small">A brief note about this revision. Shows up on the version-history page so readers can scan changes without diffing the abstract by hand.</p>
    <label>
      <span class="label-text">Change summary</span>
      <textarea name="diff_summary" maxlength="500" rows="3" placeholder="e.g. 'Tightened the bound in Section 3 after a referee comment.'"></textarea>
      <span class="hint">≤ 500 characters. Shown verbatim on <a href="/m/<%= encodeURIComponent(m.arxiv_like_id) %>/versions" target="_blank" rel="noopener">/m/<%= m.arxiv_like_id %>/versions</a>.</span>
    </label>
  </section>
  <% } %>

  <div class="form-submit">
    <button type="submit" class="btn-primary big"><%= isEditing ? 'Save changes' : 'Post manuscript' %></button>
    <% if (isEditing) { %>
      <a class="btn-secondary" href="/m/<%= encodeURIComponent(m.arxiv_like_id) %>">Cancel</a>
      <span class="muted small">The id, DOI, and original submission timestamp stay the same. A version snapshot is saved before each edit.</span>
    <% } else { %>
      <span class="muted small">By submitting you confirm the work was conducted by you (and the AI you named).</span>
    <% } %>
  </div>
</form>

<script>
  (function () {
    const cb = document.getElementById('has_auditor');
    const af = document.getElementById('auditor-fields');
    const nb = document.getElementById('no-auditor-block');
    const radios = document.querySelectorAll('input[name="conductor_type"]');
    const haSec  = document.getElementById('ctype-human-ai');
    const agSec  = document.getElementById('ctype-ai-agent');

    function syncAuditor() {
      const t = document.querySelector('input[name="conductor_type"]:checked');
      const isAgent = t && t.value === 'ai-agent';
      af.style.display = cb.checked ? '' : 'none';
      nb.style.display = (cb.checked || isAgent) ? 'none' : '';
      const noAuditorCheckbox = nb.querySelector('input[name="no_auditor_ack"]');
      if (noAuditorCheckbox) noAuditorCheckbox.required = !isAgent && !cb.checked;
      af.querySelectorAll('input[name="auditor_name"], select[name="auditor_role"], textarea[name="auditor_statement"]')
        .forEach((el) => { el.required = cb.checked; });
    }
    function syncCType() {
      const t = document.querySelector('input[name="conductor_type"]:checked');
      const isAgent = t && t.value === 'ai-agent';
      haSec.style.display = isAgent ? 'none' : '';
      agSec.style.display = isAgent ? '' : 'none';
      // The "submitter not responsible for correctness" ack is only meaningful
      // when there's a human conductor; the AI-agent path has its own ack.
      const noAuditorCheckbox = nb.querySelector('input[name="no_auditor_ack"]');
      const aiAgentCheckbox = agSec.querySelector('input[name="ai_agent_ack"]');
      if (isAgent) {
        nb.style.display = 'none';
      } else if (!cb.checked) {
        nb.style.display = '';
      }
      // Required attribute on conductor_human / conductor_role
      const ch = document.querySelector('input[name="conductor_human"]');
      const cr = document.querySelector('select[name="conductor_role"]');
      if (ch) ch.required = !isAgent;
      if (cr) cr.required = !isAgent;
      if (noAuditorCheckbox) noAuditorCheckbox.required = !isAgent && !cb.checked;
      if (aiAgentCheckbox) aiAgentCheckbox.required = isAgent;
      syncAuditor();
    }
    cb.addEventListener('change', syncAuditor);
    for (const r of radios) r.addEventListener('change', syncCType);
    syncCType();
  })();
</script>

<%- include('partials/footer') %>
